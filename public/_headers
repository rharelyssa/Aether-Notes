/*
  # Strict Content Security Policy for Aether Notes
  # Güvenlik kararları:
  # - script-src 'self' 'unsafe-inline': CRA build inline script gerektiriyor
  # - connect-src 'none': hiçbir ağ isteğine izin yok (local-only app)
  # - frame-src 'none': iframe embedding engellendi
  # - object-src 'none': Flash/plugin yok
  # - base-uri 'self': base tag injection engellendi
  # - form-action 'none': form submission yok
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'none'; frame-src 'none'; object-src 'none'; base-uri 'self'; form-action 'none';
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
